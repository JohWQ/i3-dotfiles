## i3 config file (v4)
# Please see https://i3wm.org/docs/userguide.html for a complete reference!
# Should you change your keyboard layout some time, delete
# this file and re-run i3-config-wizard(1).

set $mod Mod4

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart


# i3 style names        border  backgr. text    indica. childb.

# type:                 layout  layout  invisi. bug_li. border
# status:               nah     nah     nah     clone   hmm
client.focused          #0a76c7 #0a76c7 #ffffff #0a76c7 #0a76c7
client.focused_inactive #495e73 #495e73 #ffffff #495e73 #495e73
client.unfocused        #343434 #343434 #ffffff #343434 #343434
client.urgent           #87ceeb #87ceeb #104b63 #87ceeb #87ceeb
client.placeholder      #000000 #0c0c0c #ffffff #000000 #0c0c0c
client.background       #ffffff


# Autostarting applications/tasks

# Desktop wallpaper with feh
exec_always --no-startup-id feh --bg-fill ~/Pictures/default.jxl

# picom compositor start
exec --no-startup-id picom --daemon --config ~/.config/picom/picom.conf

# Resolution for monitor 1 & 2 (turn off freesync)
exec_always --no-startup-id xrandr --output DP-2 --primary --mode 1920x1080 --rate 144.00 --pos 0x420 --output DP-4 --mode 1920x1080 --rate 144.00 --pos 1920x0 --rotate left

# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex-autostart --autostart --environment i3

# Greenclip daemon for bindsym
exec --no-startup-id $greenclip daemon


# Font for layouts
font pango: Liberation Mono 9
#font pango:DejaVu Sans Mono 9
#font pango: CaskaydiaCove Nerd Font 8

# Window border style
title_align center
default_floating_border normal
default_border pixel 4
bindsym $mod+Shift+space floating toggle; [tiling con_id=__focused__] border pixel 4; [floating con_id=__focused__] border normal

# Window gaps
gaps inner 10
#gaps outer 6
smart_gaps on
# Toggle gaps mode
bindsym $mod+b exec --no-startup-id i3-msg bar mode toggle
bindsym $mod+Shift+b exec --no-startup-id i3-msg "gaps inner all toggle 10"


# Scratchpads
# Make the currently focused window a scratchpad
bindsym $mod+Shift+minus move scratchpad
# Show "other" scratchpads that are not set to launch with i3 on startup
bindsym $mod+minus [title="^(?!pulsemixeraterm|alaterm|yaziaterm).*"] scratchpad show; move position center

# Keybinds
bindsym Pause [class="^Alacritty$"] [title="pulsemixeraterm"] scratchpad show; move position center
bindsym $mod+Mod1+1 [class="^Alacritty$"] [title="pulsemixeraterm"] scratchpad show; move position center

#bindsym $mod+Insert [title="alaterm"] scratchpad show; move position center
bindsym $mod+Mod1+2 [class="^Alacritty$"] [title="alaterm"] scratchpad show; move position center

#bindsym $mod+Delete [title="yaziaterm"] scratchpad show; move position center
bindsym $mod+Mod1+3 [class="^Alacritty$"] [title="yaziaterm"] scratchpad show; move position center

# Launching applications for scratchpads
exec_always --no-startup-id pgrep -f '^alacritty -t pulsemixeraterm -e pulsemixer' || alacritty -t pulsemixeraterm -e pulsemixer
for_window [class="^Alacritty$"] [title="pulsemixeraterm"] move scratchpad
for_window [class="^Alacritty$"] [title="pulsemixeraterm"] resize set 700 500

exec_always --no-startup-id pgrep -f '^alacritty -t alaterm --' || alacritty -t alaterm --
for_window [class="^Alacritty$"] [title="alaterm"] move scratchpad
for_window [class="^Alacritty$"] [title="alaterm"] resize set 1000 700

exec_always --no-startup-id pgrep -f '^alacritty -t yaziaterm -e yazi' || alacritty -t yaziaterm -e yazi
for_window [class="^Alacritty$"] [title="yaziaterm"] move scratchpad
for_window [class="^Alacritty$"] [title="yaziaterm"] resize set 1000 700


# Rofi Power menu
bindsym $mod+bar exec --no-startup-id ~/.config/rofi/powermenu/type-1/powermenu.sh
bindsym $mod+Shift+Escape exec --no-startup-id ~/.config/rofi/powermenu/type-1/powermenu.sh


# Use Super + Mouse to move window
floating_modifier $mod
# Move window to center
bindsym $mod+Shift+Home move position center
bindsym $mod+Shift+End resize set 800 540, move position center
# Kill focused window
bindsym $mod+Shift+q kill
bindsym --whole-window $mod+button2 kill

# Change back to previous workspace
workspace_auto_back_and_forth yes

bindsym $mod+p workspace prev
bindsym $mod+n workspace next
bindsym $mod+Shift+p move to workspace prev, workspace prev
bindsym $mod+Shift+n move to workspace next, workspace next
bindsym $mod+Control+p move to workspace prev
bindsym $mod+Control+n move to workspace next

# move focus (vim keybindings)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right


# split in horizontal orientation
bindsym $mod+g split h
# split in vertical orientation
bindsym $mod+v split v
# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle
# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle
# focus the parent container
bindsym $mod+a focus parent
# focus the child container
bindsym $mod+q focus child

# Workspace sorting on monitor 1
set $ws1 "1:1"
set $ws2 "2:2"
set $ws3 "3:3"
set $ws4 "4:4"
set $ws5 "5:5"
set $ws6 "6:6"
set $ws11 "7:GIMP"
workspace $ws1 output DP-2
workspace $ws2 output DP-2
workspace $ws3 output DP-2
workspace $ws4 output DP-2
workspace $ws5 output DP-2
workspace $ws6 output DP-2
workspace $ws11 output DP-2

# Workspace sorting on monitor 2
set $ws7 "1:F1"
set $ws8 "2:F2"
set $ws9 "3:F3"
set $ws10 "4:F4"
workspace $ws7 output DP-4
workspace $ws8 output DP-4
workspace $ws9 output DP-4
workspace $ws10 output DP-4

# Go to workspace
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+F1 workspace $ws7
bindsym $mod+F2 workspace $ws8
bindsym $mod+F3 workspace $ws9
bindsym $mod+F4 workspace $ws10

# move focused container to workspace and go to workspace
bindsym $mod+Shift+1 move container to workspace $ws1, workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2, workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3, workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4, workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5, workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6, workspace $ws6
bindsym $mod+Shift+F1 move container to workspace $ws7, workspace $ws7
bindsym $mod+Shift+F2 move container to workspace $ws8, workspace $ws8
bindsym $mod+Shift+F3 move container to workspace $ws9, workspace $ws9
bindsym $mod+Shift+F4 move container to workspace $ws10, workspace $ws10

# move focused container to workspace
bindsym $mod+Control+1 move container to workspace $ws1
bindsym $mod+Control+2 move container to workspace $ws2
bindsym $mod+Control+3 move container to workspace $ws3
bindsym $mod+Control+4 move container to workspace $ws4
bindsym $mod+Control+5 move container to workspace $ws5
bindsym $mod+Control+6 move container to workspace $ws6
bindsym $mod+Control+F1 move container to workspace $ws7
bindsym $mod+Control+F2 move container to workspace $ws8
bindsym $mod+Control+F3 move container to workspace $ws9
bindsym $mod+Control+F4 move container to workspace $ws10


# move focused window (in layout modes & floating)
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Move floating window
# Very small move
bindsym $mod+Mod1+Shift+h move left 1 px
bindsym $mod+Mod1+Shift+j move down 1 px
bindsym $mod+Mod1+Shift+k move up 1 px
bindsym $mod+Mod1+Shift+l move right 1 px

# medium move
bindsym $mod+Control+Shift+h move left 200 px
bindsym $mod+Control+Shift+j move down 200 px
bindsym $mod+Control+Shift+k move up 200 px
bindsym $mod+Control+Shift+l move right 200 px

# Big move
bindsym $mod+Mod1+Control+Shift+h move left 600 px
bindsym $mod+Mod1+Control+Shift+j move down 600 px
bindsym $mod+Mod1+Control+Shift+k move up 600 px
bindsym $mod+Mod1+Control+Shift+l move right 600 px


# arrow keys:
# Very small move
bindsym $mod+Mod1+Shift+Up move up 1 px
bindsym $mod+Mod1+Shift+Down move down 1 px
bindsym $mod+Mod1+Shift+Left move left 1 px
bindsym $mod+Mod1+Shift+Right move right 1 px

# medium move
bindsym $mod+Control+Shift+Up move up 200 px
bindsym $mod+Control+Shift+Down move down 200 px
bindsym $mod+Control+Shift+Left move left 200 px
bindsym $mod+Control+Shift+Right move right 200 px

# Big move
bindsym $mod+Mod1+Control+Shift+Up move up 600 px
bindsym $mod+Mod1+Control+Shift+Down move down 600 px
bindsym $mod+Mod1+Control+Shift+Left move left 600 px
bindsym $mod+Mod1+Control+Shift+Right move right 600 px


# floating applications:
## Steam
for_window [class="^steam$"] [title="^Steam$"] floating enable, move position center
for_window [class="^steam$"] [title="^Steam$"] resize set 1010 600
for_window [class="^steam$"] [title="^Steam Settings$"] floating enable
for_window [class="^steam$"] [title="^Friends List$"] floating enable
for_window [class="^steam$"] [title="^Geometry Dash$"] floating disable
for_window [class="^steam$"] [title="^Portal$"] floating enable
## File management
for_window [class="^org.gnome.FileRoller$"] [title="Pakk ut"] floating disable

# start a terminal
bindsym $mod+Return exec alacritty --config-file ~/.config/alacritty/alacritty.toml
# Start without config (Nvidia bug on update)
bindsym $mod+Control+Return exec alacritty --config-file /dev/null

# application shortcuts
bindsym $mod+Mod1+f exec firefox
bindsym $mod+Mod1+m exec fooyin
bindsym $mod+Mod1+d exec vesktop
bindsym $mod+Mod1+y exec youtube-music
bindsym $mod+Mod1+n exec thunar
bindsym $mod+Mod1+o exec obs
bindsym $mod+Mod1+t exec subl
bindsym $mod+Mod1+g exec gimp
# Gimp bind for wacom tablet:
bindsym Control+Mod1+Shift+Home workspace $ws11; exec gimp

# screenshot
# key: PrtSc
bindsym Print exec --no-startup-id flameshot gui
bindsym $mod+Print --release exec --no-startup-id flameshot screen


# media shortcuts
# master volume
bindsym $mod+Prior exec --no-startup-id ~/.config/i3/scripts/volume-device.sh volume_up
bindsym $mod+Next exec --no-startup-id ~/.config/i3/scripts/volume-device.sh volume_down
bindsym $mod+Home exec --no-startup-id ~/.config/i3/scripts/volume-device.sh volume_full
bindsym $mod+Insert exec --no-startup-id ~/.config/i3/scripts/volume-device.sh volume_7
bindsym $mod+Delete exec --no-startup-id ~/.config/i3/scripts/volume-device.sh volume_3
bindsym $mod+End exec --no-startup-id ~/.config/i3/scripts/volume-device.sh volume_mute

# music player controls
bindsym Control+Mod1+Prior exec --no-startup-id ~/.config/i3/scripts/volume-player.sh volume_up
bindsym Control+Mod1+Next exec --no-startup-id ~/.config/i3/scripts/volume-player.sh volume_down
bindsym Control+Mod1+Home exec --no-startup-id ~/.config/i3/scripts/volume-player.sh volume_full
bindsym Control+Mod1+Insert exec --no-startup-id ~/.config/i3/scripts/volume-player.sh volume_7
bindsym Control+Mod1+Delete exec --no-startup-id ~/.config/i3/scripts/volume-player.sh volume_3
bindsym Control+Mod1+End exec --no-startup-id ~/.config/i3/scripts/volume-player.sh volume_mute
# music play controls
bindsym Control+Mod1+Up exec --no-startup-id playerctl play-pause
bindsym Control+Mod1+Down exec --no-startup-id playerctl stop
bindsym Control+Mod1+Left exec --no-startup-id playerctl previous
bindsym Control+Mod1+Right exec --no-startup-id playerctl next


# Rofi recently modified files
bindsym $mod+d exec --no-startup-id "fd -t f . -E Games/ -E i3status-rust/ --exec-batch ls -t . ~ | rofi -dmenu -i -p recent_home | xargs -I {} ~/.config/rofi/file_actions.sh {}"

# Rofi run modi command:
bindsym $mod+Shift+Tab exec --no-startup-id "rofi -config ~/.config/rofi/launchers/type-1/style-5.rasi -show run"
# Rofi app modi:
bindsym $mod+Tab exec --no-startup-id "rofi -config ~/.config/rofi/launchers/type-1/style-5.rasi -show drun"
# Rofi window modi:
bindsym Mod1+Tab exec --no-startup-id "rofi -config ~/.config/rofi/launchers/type-1/style-5.rasi -show window"

# Rofi Clipboard manager:
set $greenclip /usr/local/bin/greenclip
bindsym $mod+c exec --no-startup-id "rofi -modi 'clipboard:greenclip print' -show clipboard -run-command '{cmd}'"
# Rofi-calc Calculator:
bindsym $mod+m exec --no-startup-id "rofi -config ~/.config/rofi/launchers/type-1/style-5.rasi -show calc"


# resize without entering resize mode ("2px or 2 ppt"):
bindsym $mod+Control+h exec --no-startup-id ~/.config/i3/scripts/i3resize.sh left
bindsym $mod+Control+l exec --no-startup-id ~/.config/i3/scripts/i3resize.sh right
bindsym $mod+Control+k exec --no-startup-id ~/.config/i3/scripts/i3resize.sh up
bindsym $mod+Control+j exec --no-startup-id ~/.config/i3/scripts/i3resize.sh down
bindsym $mod+Control+Left exec --no-startup-id ~/.config/i3/scripts/i3resize.sh left
bindsym $mod+Control+Right exec --no-startup-id ~/.config/i3/scripts/i3resize.sh right
bindsym $mod+Control+Up exec --no-startup-id ~/.config/i3/scripts/i3resize.sh up
bindsym $mod+Control+Down exec --no-startup-id ~/.config/i3/scripts/i3resize.sh down

# resize window (you can also use the mouse for that)
mode "Resize mode" {
        # These bindings trigger as soon as you enter the resize mode

	# move focused window in resize mode
	bindsym $mod+Shift+Home move position center
	bindsym $mod+Shift+End resize set 800 540, move position center
	# Vim keys
#	bindsym $mod+Shift+h move left
#	bindsym $mod+Shift+j move down
#	bindsym $mod+Shift+k move up
#	bindsym $mod+Shift+l move right
	# larger distances
	bindsym $mod+Control+Shift+h move left 200 px
	bindsym $mod+Control+Shift+j move down 200 px
	bindsym $mod+Control+Shift+k move up 200 px
	bindsym $mod+Control+Shift+l move right 200 px
	# Same binds, but for arrow keys
	bindsym $mod+Shift+Left move left
	bindsym $mod+Shift+Down move down
	bindsym $mod+Shift+Up move up
	bindsym $mod+Shift+Right move right
	#larger distances
	bindsym $mod+Control+Shift+Left move left 200 px
	bindsym $mod+Control+Shift+Down move down 200 px
	bindsym $mod+Control+Shift+Up move up 200 px
	bindsym $mod+Control+Shift+Right move right 200 px

        # inverted resize binds
        bindsym l resize shrink width 5 px or 5 ppt
        bindsym k resize grow height 5 px or 5 ppt
        bindsym j resize shrink height 5 px or 5 ppt
        bindsym h resize grow width 5 px or 5 ppt

        # small resize
        bindsym Mod1+l resize shrink width 1 px or 1 ppt
        bindsym Mod1+k resize grow height 1 px or 1 ppt
        bindsym Mod1+j resize shrink height 1 px or 1 ppt
        bindsym Mod1+h resize grow width 1 px or 1 ppt

        # medium resize
        bindsym Shift+l resize shrink width 40 px or 40 ppt
        bindsym Shift+k resize grow height 40 px or 40 ppt
        bindsym Shift+j resize shrink height 40 px or 40 ppt
        bindsym Shift+h resize grow width 40 px or 40 ppt

        # large resize
        bindsym $mod+l resize shrink width 80 px or 80 ppt
        bindsym $mod+k resize grow height 80 px or 80 ppt
        bindsym $mod+j resize shrink height 80 px or 80 ppt
        bindsym $mod+h resize grow width 80 px or 80 ppt

        # very large resize
        bindsym Control+l resize shrink width 300 px or 300 ppt
        bindsym Control+k resize grow height 300 px or 300 ppt
        bindsym Control+j resize shrink height 300 px or 300 ppt
        bindsym Control+h resize grow width 300 px or 300 ppt

        # mega resize
        bindsym $mod+Control+l resize shrink width 600 px or 600 ppt
        bindsym $mod+Control+k resize grow height 600 px or 600 ppt
        bindsym $mod+Control+j resize shrink height 600 px or 600 ppt
        bindsym $mod+Control+h resize grow width 600 px or 600 ppt

        # same bindings, but for the arrow keys
        bindsym Right resize shrink width 5 px or 5 ppt
        bindsym Up resize grow height 5 px or 5 ppt
        bindsym Down resize shrink height 5 px or 5 ppt
        bindsym Left resize grow width 5 px or 5 ppt

        # small resize
        bindsym Mod1+Right resize shrink width 1 px or 1 ppt
        bindsym Mod1+Up resize grow height 1 px or 1 ppt
        bindsym Mod1+Down resize shrink height 1 px or 1 ppt
        bindsym Mod1+Left resize grow width 1 px or 1 ppt

        # medium resize
        bindsym Shift+Right resize shrink width 40 px or 40 ppt
        bindsym Shift+Up resize grow height 40 px or 40 ppt
        bindsym Shift+Down resize shrink height 40 px or 40 ppt
        bindsym Shift+Left resize grow width 40 px or 40 ppt

        # large resize
        bindsym $mod+Right resize shrink width 80 px or 80 ppt
        bindsym $mod+Up resize grow height 80 px or 80 ppt
        bindsym $mod+Down resize shrink height 80 px or 80 ppt
        bindsym $mod+Left resize grow width 80 px or 80 ppt

        # very large resize
        bindsym Control+Right resize shrink width 300 px or 300 ppt
        bindsym Control+Up resize grow height 300 px or 300 ppt
        bindsym Control+Down resize shrink height 300 px or 300 ppt
        bindsym Control+Left resize grow width 300 px or 300 ppt

        # mega resize
        bindsym $mod+Control+Right resize shrink width 600 px or 600 ppt
        bindsym $mod+Control+Up resize grow height 600 px or 600 ppt
        bindsym $mod+Control+Down resize shrink height 600 px or 600 ppt
        bindsym $mod+Control+Left resize grow width 600 px or 600 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
        bindsym Control+c mode "default"
        bindsym BackSpace mode "default"
        bindsym Delete mode "default"
}

bindsym $mod+r mode "Resize mode"


# --------------- horizontal monitor bar --------------- #
bar {
    output primary
    font pango: CaskaydiaCove Nerd Font 16
    position top
    tray_output none
    strip_workspace_numbers yes
    status_command ~/i3status-rust/target/release/i3status-rs ~/.config/i3status-rust/config.toml

    colors {
        background #1f2633
#                          outline fill    text
    	urgent_workspace   #87ceeb #87ceeb #104b63
        focused_workspace  #0a76c7 #0a76c7 #ffffff
#       inactive but active:
        active_workspace   #495e73 #495e73 #999999
        inactive_workspace #1f2633 #1f2633 #777777
    }
}

# --------------- vertical monitor bar --------------- #
bar {
    output DP-4
    font pango: CaskaydiaCove Nerd Font 13
    position top
    tray_output DP-4
    tray_padding 2
    strip_workspace_numbers yes
    status_command ~/i3status-rust/target/release/i3status-rs ~/.config/i3status-rust/2ndconfig.toml

    colors {
        background #1f2633
#                          outline fill    text
    	urgent_workspace   #87ceeb #87ceeb #104b63
        focused_workspace  #0a76c7 #0a76c7 #ffffff
#       inactive but active:
        active_workspace   #495e73 #495e73 #999999
        inactive_workspace #1f2633 #1f2633 #777777
    }
}
